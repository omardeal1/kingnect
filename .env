# URL de conexión a la base de datos (SQLite local)
DATABASE_URL=file:/home/z/my-project/db/custom.db

# Nombre público de la aplicación que se muestra en la interfaz
NEXT_PUBLIC_APP_NAME=Kingnect

# URL base de la aplicación accesible desde el navegador
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secreto para firmar tokens de NextAuth (cambiar en producción)
NEXTAUTH_SECRET=k1ngn3ct-s3cr3t-ch4ng3-m3-1n-pr0duct10n-2024

# URL de callback para NextAuth (debe coincidir con NEXT_PUBLIC_APP_URL)
NEXTAUTH_URL=http://localhost:3000

# Clave privada de Stripe para procesar pagos desde el backend
STRIPE_SECRET_KEY=sk_test_placeholder_change_in_production

# Secreto para verificar webhooks entrantes de Stripe
STRIPE_WEBHOOK_SECRET=whsec_placeholder_change_in_production

# Clave pública de Stripe para el frontend (Stripe.js / Elements)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder_change_in_production

# Clave de API de Google Maps para mapas y autocompletado de direcciones
GOOGLE_MAPS_API_KEY=AIza_placeholder_change_in_production

# Supabase Storage (para uploads en producción)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-placeholder
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-placeholder

# Sentry (monitoreo de errores en producción)
